# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your_gemini_api_key_here

# Facebook Page Access Token
# Get from: https://developers.facebook.com/docs/facebook-login/access-tokens
# Must have pages_manage_posts and pages_read_engagement permissions
FACEBOOK_ACCESS_TOKEN=your_facebook_page_access_token_here

# NewsAPI Key (for fetching Philippine trending news)
# Get from: https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here

# Google Sheets ID (optional, for logging)
# Format: The ID from your Google Sheets URL
GOOGLE_SHEETS_ID=your_google_sheets_id_here

# Pollinations API Key (optional, usually not needed for free tier)
POLLINATIONS_API_KEY=
